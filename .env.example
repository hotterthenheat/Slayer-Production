# =============================================================================
# Environment variables for slayer-trade.
# Copy to .env (server-side, gitignored) and/or .env.local (Vite client vars).
# Do NOT commit real secrets — this file documents names only.
# =============================================================================

# --- App ---
# APP_URL: Public base URL where this app is hosted. Used to build Stripe
# Checkout success/cancel redirect URLs. Defaults to http://localhost:3000.
APP_URL=

# --- Stripe (billing) ---
# STRIPE_SECRET_KEY: Stripe secret API key (sk_test_... / sk_live_...).
# When unset, billing endpoints respond 503 ("Payments are not configured yet.").
STRIPE_SECRET_KEY=
# STRIPE_WEBHOOK_SECRET: Signing secret (whsec_...) for the /api/billing/webhook
# endpoint. Get it from the Stripe CLI (`stripe listen`) or the Dashboard webhook.
STRIPE_WEBHOOK_SECRET=
# VITE_STRIPE_PUBLISHABLE_KEY: Stripe publishable key (pk_test_... / pk_live_...).
# Exposed to the browser via Vite; safe to ship to the client.
VITE_STRIPE_PUBLISHABLE_KEY=

# --- Database (Postgres) ---
# Runtime connection (src/db/index.ts).
SQL_HOST=
SQL_USER=
SQL_PASSWORD=
SQL_DB_NAME=
# Drizzle Kit migrations (src/db/drizzle.config.ts) use admin credentials:
# SQL_ADMIN_USER=
# SQL_ADMIN_PASSWORD=

# --- Optional market data providers ---
# POLYGON_API_KEY=
# TRADIER_API_KEY=
# TRADIER_ENV=sandbox

# --- Server / security ---
# COOKIE_SECRET: HMAC secret for signing session cookies. MUST be set in
# production (else an ephemeral random one is generated and sessions drop on
# restart). On Render this is auto-generated via render.yaml.
COOKIE_SECRET=
# ADMIN_EMAILS: comma-separated emails granted admin access.
ADMIN_EMAILS=
# NODE_ENV: 'production' on a deployed host (serves the built frontend).
NODE_ENV=
# JSON_BODY_LIMIT: optional override for the JSON body size cap (default ~12mb).
# JSON_BODY_LIMIT=

# NOTE: Firebase web config is currently read from firebase-applet-config.json,
# not from VITE_* env vars, so no Firebase env vars are required in src today.
